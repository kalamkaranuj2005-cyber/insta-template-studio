# Server
PORT=5000
NODE_ENV=development

# Optional: Meta/Facebook app credentials enable Instagram oEmbed.
# Without these the app falls back to Open Graph + manual upload.
# Create at https://developers.facebook.com/ -> App -> oEmbed Read.
FB_APP_ID=
FB_APP_TOKEN=

# Watermark behavior. Set to "false" once a user has a paid plan.
FREE_TIER_WATERMARK=true

# Where exports / uploads land (paths relative to backend/)
UPLOAD_DIR=uploads
EXPORT_DIR=exports

# Max upload size (bytes). Default 50 MB.
MAX_UPLOAD_BYTES=52428800
